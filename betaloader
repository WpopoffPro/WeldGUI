--- ANIMATION LOGIC ---

local function playIntro()
    local fadeInInfo = TweenInfo.new(1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    
    TweenService:Create(header, fadeInInfo, {BackgroundTransparency = 0}):Play()
    TweenService:Create(title, fadeInInfo, {TextTransparency = 0}):Play()
    TweenService:Create(desc, fadeInInfo, {TextTransparency = 0}):Play()
    TweenService:Create(pBar, fadeInInfo, {BackgroundTransparency = 0}):Play()
    TweenService:Create(bar, fadeInInfo, {BackgroundTransparency = 0}):Play()
    
    local fillInfo = TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local fillTween = TweenService:Create(bar, fillInfo, {Size = UDim2.new(1, 0, 1, 0)})
    fillTween:Play()
    
    return fillTween
end

local function fadeOut(duration)
    local fadeOutInfo = TweenInfo.new(duration, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    TweenService:Create(header, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(title, fadeOutInfo, {TextTransparency = 1}):Play()
    TweenService:Create(desc, fadeOutInfo, {TextTransparency = 1}):Play()
    TweenService:Create(pBar, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    local last = TweenService:Create(bar, fadeOutInfo, {BackgroundTransparency = 1})
    last:Play()
    return last
end

